---
layout: layout.njk
title: Artículos del Blog
---

<h2>📝 Últimos artículos</h2>
<ul class="post-list">
  {% for post in collections.posts | reverse %}
    <li class="post-item">
      <a href="{{ post.url }}" class="post-link">
        <strong>{{ post.data.title }}</strong>
      </a>
      {% if post.data.fecha %}
        <div class="post-date">📅 {{ post.data.fecha }}</div>
      {% endif %}
    </li>
  {% endfor %}
</ul>
